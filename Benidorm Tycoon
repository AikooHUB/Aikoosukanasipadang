local function populateSampah()
    local qs1 = Workspace:FindFirstChild("QuestSemanal1")
    if not qs1 then return end
    local basura = qs1:FindFirstChild("Basura") or qs1:FindFirstChild("BasuraContenedor")
    if not basura then
        for _, child in ipairs(qs1:GetChildren()) do
            if child:IsA("Folder") and child.Name:lower():find("basura") then
                basura = child
                break
            end
        end
    end
    if not basura then return end

    for _, child in ipairs(sampahList:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then child:Destroy() end
    end

    local items = {}
    for _, obj in ipairs(basura:GetChildren()) do
        local num = string.match(obj.Name, "^PilaBasura_(%d+)$")
        if num then
            local n = tonumber(num)
            if n and n >= 1 and n <= 11 then
                table.insert(items, {Name = "Sampah " .. n, Obj = obj})
            end
        end
    end
    table.sort(items, function(a,b)
        return tonumber(string.match(a.Name,"%d+")) < tonumber(string.match(b.Name,"%d+"))
    end)

    for _, item in ipairs(items) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1, -4, 0, 22)
        row.BackgroundColor3 = Color3.fromRGB(58,58,60)
        row.BackgroundTransparency = 0.35
        row.Text = item.Name
        row.TextColor3 = Color3.new(1,1,1)
        row.Font = Enum.Font.Gotham
        row.TextSize = 11
        row.AutoButtonColor = false
        row.BorderSizePixel = 0
        row.Parent = sampahList
        Instance.new("UICorner", row).CornerRadius = UDim.new(0,4)

        row.MouseButton1Click:Connect(function()
            local pos = nil
            local obj = item.Obj
            if obj:IsA("BasePart") then
                pos = obj.Position
            elseif obj:IsA("Model") then
                local pp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                if pp then pos = pp.Position end
            elseif obj:IsA("Folder") then
                for _, c in ipairs(obj:GetDescendants()) do
                    if c:IsA("BasePart") then pos = c.Position break end
                end
            end
            if pos then
                local char = Player.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0,5,0))
                end
            end
        end)
    end
    sampahList.CanvasSize = UDim2.new(0,0,0, math.max(#items * 26, 1))
end

spawn(function()
    while true do
        task.wait(2)
        populateSampah()
    end
end)

