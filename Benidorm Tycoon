-- ==================== TELEPORT FUNCTION ====================
local function teleportToPath(pathTable)
    local current = Workspace
    for _, name in ipairs(pathTable) do
        if not current then break end
        local nextObj = current:FindFirstChild(name)
        if nextObj then
            current = nextObj
        else
            current = nil
            break
        end
    end

    if current then
        local targetPart = nil
        if current:IsA("BasePart") then
            targetPart = current
        elseif current:IsA("Model") then
            targetPart = current.PrimaryPart or current:FindFirstChildWhichIsA("BasePart")
        elseif current:IsA("Folder") then
            for _, child in ipairs(current:GetDescendants()) do
                if child:IsA("BasePart") then
                    targetPart = child
                    break
                end
            end
        end
        if targetPart then
            local char = Player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 5, 0))
            end
        end
    end
end

