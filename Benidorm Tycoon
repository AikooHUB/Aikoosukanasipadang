-- ==================== POP UP FUNCTION ====================
local activePopups = {}
local function showPopup(text)
    for _, p in ipairs(activePopups) do
        if p and p.Parent then p:Destroy() end
    end
    table.clear(activePopups)

    local popup = Instance.new("Frame")
    popup.Size = UDim2.new(0, 300, 0, 60)
    popup.Position = UDim2.new(0.5, -150, 0.5, -30)
    popup.BackgroundColor3 = Color3.fromRGB(22,22,22)
    popup.BackgroundTransparency = 1
    popup.BorderSizePixel = 0
    popup.Parent = ScreenGui
    Instance.new("UICorner", popup).CornerRadius = UDim.new(0, 14)
    local stroke = Instance.new("UIStroke", popup)
    stroke.Color = Color3.fromRGB(65,65,65)
    stroke.Thickness = 1
    stroke.Transparency = 0.35

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 1, 0)
    label.Position = UDim2.new(0, 5, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 16
    label.TextTransparency = 1
    label.Parent = popup

    table.insert(activePopups, popup)

    TweenService:Create(popup, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundTransparency = 0.25}):Play()
    TweenService:Create(label, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()

    task.delay(2.5, function()
        if popup and popup.Parent then
            TweenService:Create(popup, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
            TweenService:Create(label, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {TextTransparency = 1}):Play()
            task.wait(0.5)
            if popup and popup.Parent then popup:Destroy() end
        end
        for i, p in ipairs(activePopups) do
            if p == popup then table.remove(activePopups, i) break end
        end
    end)
end

