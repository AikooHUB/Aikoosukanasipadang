-- ==================== FUNGSI DETEKSI ====================
local function getPosition(obj)
    if obj:IsA("BasePart") then
        return obj.Position
    elseif obj:IsA("Model") then
        local pp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if pp then return pp.Position end
    elseif obj:IsA("Folder") then
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("BasePart") then return child.Position end
        end
    end
    return nil
end

local function collectItems()
    local items = {}
    local itemsFolder = Workspace:FindFirstChild("Items")
    if not itemsFolder then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Folder") and obj.Name == "Items" then
                itemsFolder = obj
                break
            end
        end
    end
    if not itemsFolder then return items end

    for _, child in ipairs(itemsFolder:GetDescendants()) do
        if (child:IsA("BasePart") or child:IsA("Model") or child:IsA("Folder")) and string.find(child.Name, "%d") then
            local pos = getPosition(child)
            if pos then
                table.insert(items, {Name = child.Name, Obj = child, Position = pos})
            end
        end
    end

    table.sort(items, function(a, b)
        local numA = tonumber(string.match(a.Name, "%d+")) or 0
        local numB = tonumber(string.match(b.Name, "%d+")) or 0
        return numA < numB
    end)

    return items
end

-- Fungsi klaim terbaru: hanya mengandalkan proximity tanpa paksaan
local function gentleClaim(item)
    local obj = item.Obj
    if not obj or not obj.Parent then return false end

    -- 1. Pastikan prompt dalam keadaan aktif
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("ProximityPrompt") then
            child.Enabled = true
        end
    end

    -- 2. Dapatkan posisi terkini item
    local pos = getPosition(obj)
    if not pos then return false end

    local char = Player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    local root = char.HumanoidRootPart

    -- 3. Array posisi di sekitar item untuk mencoba memicu proximity
    local offsets = {
        Vector3.new(0, 0, 0),   -- tepat di item
        Vector3.new(0, 2, 0),   -- sedikit di atas
        Vector3.new(0, -2, 0),  -- sedikit di bawah
        Vector3.new(2, 0, 0),   -- kanan
        Vector3.new(-2, 0, 0),  -- kiri
        Vector3.new(0, 0, 2),   -- depan
        Vector3.new(0, 0, -2),  -- belakang
    }

    -- 4. Coba setiap posisi, beri waktu server mendeteksi proximity
    for _, offset in ipairs(offsets) do
        if not obj.Parent then return true end -- item hilang, berhasil!
        root.CFrame = CFrame.new(pos + offset)
        -- Beri jeda 0.5 detik di setiap posisi agar prompt sempat terpicu
        task.wait(0.5)
    end

    -- 5. Kembali ke posisi item dan tunggu sebentar lagi
    root.CFrame = CFrame.new(pos)
    task.wait(0.5)

    return not obj.Parent -- true jika item hilang
end

