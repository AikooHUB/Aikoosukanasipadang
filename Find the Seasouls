-- ==================== FOLDER TARGET ====================
local seasoulsFolder = workspace:FindFirstChild("Seasouls")
local conchasFolder = workspace:FindFirstChild("ConchasSalvajes")

-- Tunggu maksimal 10 detik
local waited = 0
while (not seasoulsFolder or not conchasFolder) and waited < 10 do
	task.wait(0.5)
	if not seasoulsFolder then
		seasoulsFolder = workspace:FindFirstChild("Seasouls")
		if not seasoulsFolder then
			for _, v in ipairs(workspace:GetDescendants()) do
				if v:IsA("Folder") and v.Name == "Seasouls" then seasoulsFolder = v break end
			end
		end
	end
	if not conchasFolder then
		conchasFolder = workspace:FindFirstChild("ConchasSalvajes")
		if not conchasFolder then
			for _, v in ipairs(workspace:GetDescendants()) do
				if v:IsA("Folder") and v.Name == "ConchasSalvajes" then conchasFolder = v break end
			end
		end
	end
	waited = waited + 0.5
end

-- ==================== FUNGSI UTAMA ====================
local currentTarget = "seasouls"
local stop = false
local autoTP = false
local stopTP = false

-- Dapatkan posisi teleport dari objek
local function getPosition(obj)
	if obj:IsA("BasePart") then return obj.Position
	elseif obj:IsA("Model") then
		local pp = obj.PrimaryPart
		if pp then return pp.Position end
		local part = obj:FindFirstChildWhichIsA("BasePart")
		if part then return part.Position end
	end
	return nil
end

-- Ambil item sesuai target (Summer01-40 atau Shell1-n)
local function getItems()
	local items = {}
	if currentTarget == "seasouls" and seasoulsFolder then
		for _, child in ipairs(seasoulsFolder:GetChildren()) do
			local name = child.Name
			local num = string.match(name, "^Summer(%d+)$")
			if num then
				local n = tonumber(num)
				if n and n >= 1 and n <= 40 then
					local pos = getPosition(child)
					if pos then
						table.insert(items, {Name = name, Position = pos + Vector3.new(0, 5, 0)})
					end
				end
			end
		end
		table.sort(items, function(a,b)
			return (tonumber(string.match(a.Name, "%d+")) or 0) < (tonumber(string.match(b.Name, "%d+")) or 0)
		end)
	elseif currentTarget == "shell" and conchasFolder then
		for _, child in ipairs(conchasFolder:GetChildren()) do
			local name = child.Name
			if name:match("^Shell") then
				local pos = getPosition(child)
				if pos then
					table.insert(items, {Name = name, Position = pos + Vector3.new(0, 5, 0)})
				end
			end
		end
		table.sort(items, function(a,b) return a.Name < b.Name end)
	end
	return items
end

-- Teleport semua item (bisa dihentikan lewat stopTP)
local function teleportAll()
	local items = getItems()
	if #items == 0 then return end
	for _, item in ipairs(items) do
		if stopTP or stop then break end
		local char = p.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = CFrame.new(item.Position)
		end
		task.wait(0.8)
	end
end

-- Loop Auto TP
local function autoTPLoop()
	while autoTP and not stop do
		teleportAll()
		task.wait(1)
	end
end

