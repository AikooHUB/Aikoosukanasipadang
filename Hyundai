-- ==================== DATA FOLDER ====================
local treasureFolder = nil
local worldcupFolder = nil

local function findFolders()
	-- TreasurePartFolder
	treasureFolder = Workspace:FindFirstChild("TreasurePartFolder")
	if not treasureFolder then
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("Folder") and obj.Name == "TreasurePartFolder" then
				treasureFolder = obj
				break
			end
		end
	end
	-- Worldcup_Box
	worldcupFolder = Workspace:FindFirstChild("Worldcup_Box")
	if not worldcupFolder then
		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("Folder") and obj.Name == "Worldcup_Box" then
				worldcupFolder = obj
				break
			end
		end
	end
end
findFolders()

-- Background loop pencarian folder
spawn(function()
	while not treasureFolder or not worldcupFolder do
		task.wait(0.5)
		findFolders()
	end
end)

-- ==================== FUNGSI UTAMA ====================
local currentTarget = "treasure" -- "treasure" atau "worldcup"
local stop = false
local autoTP = false
local bypass = false

local function getPosition(obj)
	if obj:IsA("BasePart") then
		return obj.Position
	elseif obj:IsA("Model") then
		local pp = obj.PrimaryPart
		if pp then return pp.Position end
		local part = obj:FindFirstChildWhichIsA("BasePart")
		if part then return part.Position end
	elseif obj:IsA("Folder") then
		for _, child in ipairs(obj:GetDescendants()) do
			if child:IsA("BasePart") then return child.Position end
		end
	end
	return nil
end

local function getItems()
	local folder = currentTarget == "treasure" and treasureFolder or worldcupFolder
	local items = {}
	if not folder then return items end
	for _, child in ipairs(folder:GetChildren()) do
		local pos = getPosition(child)
		if pos then
			table.insert(items, {Name = child.Name, Position = pos + Vector3.new(0, 5, 0)})
		end
	end
	table.sort(items, function(a,b) return a.Name < b.Name end)
	return items
end

local function teleportAll()
	local items = getItems()
	if #items == 0 then return end
	local delayTime = bypass and 0 or 0.8
	for _, item in ipairs(items) do
		if stop or not autoTP then break end
		local char = Player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.CFrame = CFrame.new(item.Position)
		end
		task.wait(delayTime)
	end
end

local function autoTPLoop()
	while autoTP and not stop do
		teleportAll()
		task.wait(bypass and 0.5 or 1)
	end
end

